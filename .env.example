# Root-level environment variables for local development.
# Copy this file to .env and fill in your values.
# .env is gitignored and should NEVER be committed.

# PostgreSQL
POSTGRES_USER=shipyard
POSTGRES_PASSWORD=changeme
POSTGRES_DB=shipyard
# If you change POSTGRES_PASSWORD after Postgres was first created, the old password stays
# in the Docker volume. Fix: set DB_PASSWORD / POSTGRES_PASSWORD back to the original value,
# or remove the volume (e.g. docker compose down -v) and bring the stack up again.

# todo-service (local run). In Docker Compose, PORT is set per service (8080 / 8081).
PORT=8080
DB_HOST=postgres
DB_PORT=5432
DB_USER=shipyard
DB_PASSWORD=changeme
DB_NAME=shipyard
DB_SSLMODE=disable

# Shared by auth-service and todo-service (JWT signing + verification)
JWT_SECRET=change_me_to_a_long_random_string
