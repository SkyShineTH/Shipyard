# auth-service — environment variables
# Copy to .env and fill in your values

# Server
PORT=8081

# Database (shared postgres from docker-compose)
DB_HOST=postgres
DB_USER=shipyard
DB_PASSWORD=your_password_here
DB_NAME=shipyard
DB_PORT=5432
DB_SSLMODE=disable

# JWT
JWT_SECRET=change_me_to_a_long_random_string
